        <url-pattern>/AddReviewServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ContactUsServlet</servlet-name>
        <url-pattern>/ContactUsServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GenerateOTPServlet</servlet-name>
        <url-pattern>/GenerateOTPServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateForgotPassword</servlet-name>
        <url-pattern>/UpdateForgotPassword</url-pattern>
    </servlet-mapping>
