        <servlet-class>com.oss.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.oss.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
